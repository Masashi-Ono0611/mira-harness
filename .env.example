# Telegram API credentials — https://my.telegram.org -> API development tools
TG_API_ID=
TG_API_HASH=

# Minted by `mira-harness login`. FULL account access — keep SECRET, never commit.
TG_SESSION=

# Target bot username, no @ (default: mira)
MIRA_PEER=mira

# Optional: a group chat id for `loop --peer experiment`
TG_EXPERIMENT_CHAT=

# Optional: where to write the run log (default: ./mira-runs.jsonl)
MIRA_RUNS_FILE=
