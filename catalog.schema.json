{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "array",
  "items": {
    "type": "object",
    "properties": {
      "id": {
        "type": "string",
        "minLength": 1
      },
      "category": {
        "default": "custom",
        "type": "string"
      },
      "hypothesis": {
        "default": "",
        "type": "string"
      },
      "send": {
        "type": "string",
        "minLength": 1
      },
      "slow": {
        "type": "boolean"
      },
      "confirm": {
        "type": "boolean"
      },
      "note": {
        "type": "string"
      },
      "expect": {
        "type": "object",
        "properties": {
          "replies": {
            "type": "boolean"
          },
          "textMatches": {
            "type": "string"
          },
          "minButtons": {
            "type": "integer",
            "minimum": 0,
            "maximum": 9007199254740991
          },
          "minLinks": {
            "type": "integer",
            "minimum": 0,
            "maximum": 9007199254740991
          },
          "hasWebApp": {
            "type": "boolean"
          },
          "media": {
            "type": "string",
            "enum": ["photo", "video", "audio", "document", "webpage", "other"]
          },
          "maxFirstReplyMs": {
            "type": "number",
            "exclusiveMinimum": 0
          },
          "json": {
            "type": "boolean"
          }
        },
        "additionalProperties": false
      }
    },
    "required": ["id", "category", "hypothesis", "send"],
    "additionalProperties": false
  }
}
