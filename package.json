{
  "name": "mira-harness",
  "version": "0.1.5",
  "description": "A CLI + MCP dev-tool for communicating with the @mira Telegram bot — capture its full reply (buttons/links/media) and run a self-driving experiment catalog.",
  "type": "module",
  "bin": {
    "mira-harness": "dist/cli.js",
    "mira-harness-mcp": "dist/mcp.js"
  },
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "examples",
    "llms.txt"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "bun src/cli.ts",
    "login": "bun src/cli.ts login",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "format": "biome check --write .",
    "test": "bun test",
    "clean": "rm -rf dist",
    "build": "bun run clean && bun build src/cli.ts src/mcp.ts src/index.ts --target=node --format=esm --outdir=dist --packages=external && bun run build:types",
    "build:types": "tsc -p tsconfig.build.json",
    "prepublishOnly": "bun run build"
  },
  "keywords": [
    "telegram",
    "mira",
    "gramjs",
    "userbot",
    "bot-testing",
    "e2e",
    "cli"
  ],
  "author": "Masashi Ono",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Masashi-Ono0611/mira-harness.git"
  },
  "homepage": "https://masashi-ono0611.github.io/mira-harness/",
  "bugs": {
    "url": "https://github.com/Masashi-Ono0611/mira-harness/issues"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "commander": "^12",
    "dotenv": "^16",
    "picocolors": "^1.1.1",
    "telegram": "^2.26.22",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@types/bun": "^1.3.14",
    "@types/node": "^22",
    "typescript": "^5"
  }
}
